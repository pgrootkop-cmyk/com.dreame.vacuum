{
  "title": {
    "en": "Clean a zone"
  },
  "titleFormatted": {
    "en": "Clean zone [[zone]] [[repeats]]x"
  },
  "hint": {
    "en": "Start cleaning a saved zone. Configure zones in the app settings by drawing rectangles on the map."
  },
  "args": [
    {
      "name": "device",
      "type": "device",
      "filter": "driver_id=vacuum"
    },
    {
      "type": "autocomplete",
      "name": "zone",
      "title": {
        "en": "Zone"
      },
      "placeholder": {
        "en": "Search zones..."
      }
    },
    {
      "type": "number",
      "name": "repeats",
      "title": {
        "en": "Repeats"
      },
      "min": 1,
      "max": 3,
      "step": 1
    }
  ]
}
