{
  "title": {
    "en": "Navigate to waypoint"
  },
  "titleFormatted": {
    "en": "Navigate to [[waypoint]], then [[after_arrival]]"
  },
  "hint": {
    "en": "Send the vacuum to a specific point on the map using a tiny zone clean. Configure waypoints in app settings."
  },
  "args": [
    {
      "name": "device",
      "type": "device",
      "filter": "driver_id=vacuum"
    },
    {
      "type": "autocomplete",
      "name": "waypoint",
      "title": {
        "en": "Waypoint"
      },
      "placeholder": {
        "en": "Select a waypoint..."
      }
    },
    {
      "type": "dropdown",
      "name": "after_arrival",
      "title": {
        "en": "After arrival"
      },
      "values": [
        {
          "id": "dock",
          "title": { "en": "Return to dock" }
        },
        {
          "id": "stop",
          "title": { "en": "Stop in place" }
        }
      ]
    }
  ]
}
